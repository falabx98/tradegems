# ╔══════════════════════════════════════════════════════════════╗
# ║  TradeGems Environment Variables                            ║
# ║  Copy to .env and fill in values for local development      ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://tradingarena:localdev123@localhost:5432/tradingarena

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-64-chars-min
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Server ────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development
# WS_PORT=3001  (used by ws-gateway, not api)

# ─── CORS ──────────────────────────────────────────────────────
# Comma-separated origins. Core origins (tradegems.gg, localhost in dev) are always included.
# CORS_ORIGINS=https://yourdomain.vercel.app

# ─── Solana ────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
SOLANA_REQUIRED_CONFIRMATIONS=3

# Treasury keypair (base58-encoded). If omitted in dev, an ephemeral keypair is generated.
# ⚠️  DEVNET ONLY — NEVER copy a production key into this file.
# TREASURY_PRIVATE_KEY=

# AES-256 key for encrypting deposit wallet private keys (64-char hex string).
# ⚠️  DEVNET ONLY — NEVER copy a production key into this file.
# WALLET_ENCRYPTION_KEY=

# ─── Platform ──────────────────────────────────────────────────
PLATFORM_FEE_RATE=0.03

# ─── Admin ─────────────────────────────────────────────────────
# One-time admin setup key. Set once, use to create first admin, then remove.
# ADMIN_SETUP_KEY=

# ──────────────────────────────────────────────────────────────
# BOOTSTRAP MODE CAPS
# These defaults are conservative for a treasury starting at 0 SOL.
# Increase gradually as treasury grows and circuit breaker is enabled.
# ──────────────────────────────────────────────────────────────

# ─── Global Bet Caps ───────────────────────────────────────────
MAX_BET_LAMPORTS=500000000              # 0.5 SOL — global max per bet
MAX_USER_LOCKED_LAMPORTS=5000000000     # 5 SOL — max total locked per user

# ─── Rug Game ──────────────────────────────────────────────────
RUG_HOUSE_EDGE=0.05                     # 5% house edge
RUG_MAX_BET_LAMPORTS=100000000          # 0.1 SOL
RUG_MAX_PAYOUT_LAMPORTS=1000000000      # 1 SOL
RUG_MAX_ROUND_EXPOSURE_LAMPORTS=5000000000  # 5 SOL
RUG_MAX_MULTIPLIER=100                  # 100x cap

# ─── Mines ─────────────────────────────────────────────────────
MINES_MAX_BET_LAMPORTS=100000000        # 0.1 SOL
MINES_MAX_PAYOUT_LAMPORTS=1000000000    # 1 SOL

# ─── Predictions ───────────────────────────────────────────────
PREDICTIONS_MAX_BET_LAMPORTS=100000000  # 0.1 SOL
PREDICTIONS_MAX_PAYOUT_LAMPORTS=1000000000  # 1 SOL

# ─── Solo ──────────────────────────────────────────────────────
SOLO_MAX_BET_LAMPORTS=100000000         # 0.1 SOL
SOLO_MAX_PAYOUT_LAMPORTS=1000000000     # 1 SOL

# ─── Candleflip ────────────────────────────────────────────────
CANDLEFLIP_MAX_BET_LAMPORTS=100000000   # 0.1 SOL
CANDLEFLIP_MAX_PAYOUT_LAMPORTS=1000000000  # 1 SOL

# ─── Battle/Tournament ─────────────────────────────────────────
BATTLE_MAX_BET_LAMPORTS=100000000       # 0.1 SOL
BATTLE_MAX_PAYOUT_LAMPORTS=1000000000   # 1 SOL

# ──────────────────────────────────────────────────────────────
# WITHDRAWAL & TREASURY SAFETY
# ──────────────────────────────────────────────────────────────
WITHDRAWAL_FEE_LAMPORTS=5000            # Solana tx fee passed to user
WITHDRAWAL_DELAY_HOURS=24               # Hold withdrawals for 24h before processing
WITHDRAWAL_WORKER_INTERVAL_MS=300000    # Process queue every 5 min
WITHDRAWAL_BUFFER_PERCENT=10            # Reserve 10% buffer beyond pending withdrawals

# Treasury liquidity thresholds (informational alerts)
TREASURY_LIQUIDITY_WARNING_LAMPORTS=5000000000    # 5 SOL
TREASURY_LIQUIDITY_CRITICAL_LAMPORTS=1000000000   # 1 SOL

# Circuit breaker (treasury-based automatic game pausing)
ENABLE_CIRCUIT_BREAKER=false            # false = bootstrap mode (no auto-pausing)
CIRCUIT_BREAKER_BET_REDUCTION=0.5       # Reduce max bets to 50% at warning level

# ─── Deposit Sweeping ─────────────────────────────────────────
DEPOSIT_SWEEP_INTERVAL_MS=60000         # Check deposit wallets every 60s
DEPOSIT_MIN_SWEEP_LAMPORTS=5000         # Min balance to trigger sweep

# ──────────────────────────────────────────────────────────────
# ALERT DISPATCHER (ops notifications)
# ──────────────────────────────────────────────────────────────
# Telegram — create bot via @BotFather, add to ops group
# OPS_TELEGRAM_BOT_TOKEN=
# OPS_TELEGRAM_CHAT_ID=

# Discord — create webhook in your ops channel
# OPS_DISCORD_WEBHOOK_URL=

# ─── Sentry (error tracking) ──────────────────────────────────
# SENTRY_DSN=
